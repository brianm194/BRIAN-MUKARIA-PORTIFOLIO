*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    font-family:Arial, sans-serif;
}

header{
    background:#0A192F;
    color:white;
    padding:20px;
}

nav{
    display:flex;
    justify-content:space-between;
    align-items:center;
}

nav ul{
    display:flex;
    list-style:none;
}

nav ul li{
    margin-left:20px;
}

nav a{
    color:white;
    text-decoration:none;
}

#home{
    height:90vh;
    display:flex;
    flex-direction:column;
    justify-content:center;
    align-items:center;
    text-align:center;
    background:#f5f5f5;
}

#home h1{
    font-size:3rem;
    margin-bottom:20px;
}

#home p{
    width:60%;
    line-height:1.8;
    margin-bottom:20px;
}

#home a{
    background:#2E8B57;
    color:white;
    padding:12px 24px;
    text-decoration:none;
    border-radius:5px;
}